# Copy this file to .env.docker and fill in your local or hosted Supabase values.
#
# For Supabase local development, run `supabase start` from backend/ first,
# then copy the API URL, anon key, and service_role key from the CLI output.

SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_ANON_KEY=replace_with_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Current route-correction-worker supports the stub provider only.
ROUTE_MATCH_PROVIDER=stub
